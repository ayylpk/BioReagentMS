<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.bioreagent.mapper.OutboundOrderAuditMapper">
    <select id="list" parameterType="com.bioreagent.QueryParam.DeliveryOrderQueryParam" resultType="com.bioreagent.entity.DeliveryOrder">
        SELECT
        id,
        order_number,
        reagent_id,
        reagent_name,
        quantity,
        operator_id,
        operator_name,
        delivery_time,
        status,
        approver_id,
        approver_name,
        approval_time,
        rejection_reason,
        remark
        FROM delivery_order
        <where>
            status = 0
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="orderNumber != null and orderNumber != ''">
                AND order_number = #{orderNumber}
            </if>
            <if test="reagentName != null and reagentName != ''">
                AND reagent_name LIKE CONCAT('%', #{reagentName}, '%')
            </if>
            <if test="operatorId != null">
                AND operator_id = #{operatorId}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY id DESC
    </select>

</mapper>